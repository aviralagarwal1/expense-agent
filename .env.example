# Supabase project URL (Dashboard → Settings → API → Project URL)
SUPABASE_URL=

# Supabase service role key — server only; never expose to the browser (Dashboard → Settings → API)
SUPABASE_SERVICE_KEY=

# Public origin of this app, no trailing slash (e.g. https://your-service-xxx.run.app).
# Used for OAuth redirect construction. For local dev, http://127.0.0.1:5000 is fine.
APP_URL=

# Optional hosted demo credits.
# Leaving HOSTED_AI_API_KEY blank disables hosted credits and falls back to BYO-key only.
# When set, signed-in users can extract screenshots without adding their own provider key.
# The hosted key is server-side only — never paste it on the in-app API key page.
# The public app uses a 10-screenshot daily cap.
HOSTED_AI_PROVIDER=anthropic
HOSTED_AI_API_KEY=
HOSTED_DAILY_SCREENSHOT_LIMIT=10
